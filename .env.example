PORT=50000
APP_ACCESS_TOKEN=
LOG_REQUEST_BODY=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_SUPERVISOR_MODEL=gemini-3.5-flash
GEMINI_SUPERVISOR_TIMEOUT_MS=45000
GEMINI_INCLUDE_THOUGHTS=true
GEMINI_THINKING_BUDGET=2048
GEMINI_TIMEOUT_MS=90000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_MS=1500
APP_TIMEZONE=Asia/Seoul
# 평일 6회 일일 보고(22·23·06·09·10·18시)는 기본 preset 사용. 레거시 단일 cron만 쓰려면:
# MANAGER_BRIEF_PRESET_SCHEDULE=false
# AI_DAILY_CRON=5 21 * * *
MANAGER_BRIEF_PRESET_SCHEDULE=true
AI_DAILY_CRON=
TZ=Asia/Seoul
MARKET_DATA_ENABLED=true
MARKET_DATA_PROVIDER=finnhub
MARKET_US_PROVIDER=finnhub
MARKET_KR_PROVIDER=public-data-portal
MARKET_FX_PROVIDER=yahoo-finance
MARKET_REFRESH_INTERVAL_MS=60000
MARKET_QUOTE_TTL_MS=60000
MARKET_KR_QUOTE_TTL_MS=600000
# 게이트웨이 하위 경로 배포 시 필수 (예: /simpleStock/). 단독 실행·로컬 dev 는 비워 둠.
VITE_BASE_PATH=
# 한국 시세: 최근 영업일 조회 수(기본 2), 한도 초과 시 재시도 중단 시간(ms, 기본 30분)
MARKET_KR_BAS_DT_LOOKBACK_DAYS=2
MARKET_KR_QUOTA_BACKOFF_MS=1800000
FINNHUB_API_KEY=
# 공공데이터포털 「디코딩」 인증키 (Encoding 키가 아님)
PUBLIC_DATA_API_KEY=
USD_KRW_FALLBACK_RATE=1360
